<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
        xmlns:ia="clr-namespace:Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
        xmlns:viewmodels="using:VolleyStats.ViewModels"
        xmlns:domain="clr-namespace:VolleyStats.Domain"
        mc:Ignorable="d"
        x:Class="VolleyStats.Views.TeamsWindow"
        Title="Teams"
        Width="500"
        MaxWidth="500"
        MinWidth="500"
        Height="500"
        MaxHeight="500"
        MinHeight="500"
        x:DataType="viewmodels:TeamsViewModel">

    <StackPanel Margin="10" Spacing="10">

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    x:DataType="viewmodels:TeamsViewModel">
            <Button Content="NEW"
                    Command="{Binding NewTeamCommand}" />
            <Button Content="IMPORT"
                    Command="{Binding ImportTeamsCommand}" />
            <Button Content="EXPORT"
                    Command="{Binding ExportSelectedTeamCommand}" />
            <Button Content="EDIT"
                    Command="{Binding EditSelectedTeamCommand}" />
            <Button Content="DELETE"
                    Command="{Binding DeleteSelectedTeamCommand}" />
        </StackPanel>

        <ListBox x:Name="TeamsList"
         Margin="0,10,0,0"
         MaxHeight="420"
         Height="420"
         SelectionMode="Single"
         BorderThickness="1"
         CornerRadius="4"
         BorderBrush="Gray"
         x:DataType="viewmodels:TeamsViewModel"
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
         ItemsSource="{Binding Teams}"
         SelectedItem="{Binding SelectedTeam, Mode=TwoWay}">
            
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="domain:Team">
                <Border Padding="10"
                        Background="Transparent">
                  <Interaction.Behaviors>
                    <EventTriggerBehavior EventName="DoubleTapped">
                      <InvokeCommandAction
                        Command="{Binding $parent[ListBox].DataContext.EditTeamCommand}"
                        CommandParameter="{Binding}" />

                    </EventTriggerBehavior>
                  </Interaction.Behaviors>

                  <Grid ColumnDefinitions="100,*,150,80">
                    <TextBlock Grid.Column="0" Text="{Binding TeamCode}" />
                    <TextBlock Grid.Column="1" Text="{Binding Name}" />
                    <TextBlock Grid.Column="2" Text="{Binding CoachName}" />
                    <TextBlock Grid.Column="3" Text="{Binding Abbreviation}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </StackPanel>
</Window>
