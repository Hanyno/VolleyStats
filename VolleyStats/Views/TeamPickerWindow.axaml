<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="using:VolleyStats.ViewModels"
        xmlns:domain="clr-namespace:VolleyStats.Domain"
        mc:Ignorable="d"
        x:Class="VolleyStats.Views.TeamPickerWindow"
        Title="Vyberte tým"
        Width="420"
        Height="520"
        x:DataType="viewmodels:TeamPickerViewModel">

    <StackPanel Margin="12" Spacing="10">
        <TextBlock Text="Vyberte tým" FontSize="16" FontWeight="Bold" />

        <ListBox ItemsSource="{Binding Teams}"
                 SelectedItem="{Binding SelectedTeam, Mode=TwoWay}"
                 Height="380">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="domain:Team">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding Name}" />
                        <TextBlock Grid.Column="1"
                                   Margin="8,0,0,0"
                                   Foreground="Gray"
                                   Text="{Binding Abbreviation}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Zrušit" Click="CancelButton_OnClick" />
            <Button Content="Vybrat" IsEnabled="{Binding SelectedTeam}" Click="ConfirmButton_OnClick" />
        </StackPanel>
    </StackPanel>
</Window>
