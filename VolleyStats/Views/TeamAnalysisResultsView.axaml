<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VolleyStats.Views.TeamAnalysisResultsView">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,0,0,4">
            <Button x:Name="HomeButton"
                    Content="Home"
                    Width="80"
                    Click="HomeButton_OnClick" />
            <Button x:Name="BackToFilterButton"
                    Content="Back to filters"
                    Click="BackToFilterButton_OnClick" />
        </StackPanel>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0"
                       x:Name="TeamTitleTextBlock"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"
                       Text="(not selected)"/>

            <Border Grid.Row="1"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0"
                    Padding="8"
                    BorderThickness="1"
                    CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <StackPanel>
                        <TextBlock Text="Matches" FontWeight="Bold"/>
                        <TextBlock x:Name="MatchesSummaryTextBlock"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Sets" FontWeight="Bold"/>
                        <TextBlock x:Name="SetsSummaryTextBlock"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Win rate" FontWeight="Bold"/>
                        <TextBlock x:Name="WinRateSummaryTextBlock"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <HeaderedContentControl Grid.Row="2"
                  Header="Player statistics"
                  Margin="0,10,0,10">
            <DataGrid x:Name="PlayersStatsDataGrid"
                      AutoGenerateColumns="True" />
        </HeaderedContentControl>

        <Button Grid.Row="3"
                x:Name="ExportButton"
                Content="Export to PDF"
                HorizontalAlignment="Right"
                Width="130"
                Margin="0,6,0,0"
                Click="ExportButton_OnClick"/>
    </Grid>
</UserControl>
