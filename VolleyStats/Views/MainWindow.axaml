<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VolleyStats.ViewModels"
        mc:Ignorable="d"
        x:Class="VolleyStats.Views.MainWindow"
        d:DesignWidth="1200"
        d:DesignHeight="800"
        Title="VolleyStats"
        x:DataType="vm:MainWindowViewModel"
        MinWidth="800"
        MinHeight="500"
        WindowState="Maximized">

    <DockPanel>

        <!-- Tab bar -->
        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <DockPanel Height="50" Margin="10,0,8,0">

                <!-- Brand mark -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            Margin="0,0,14,0">
                    <Border Background="#2563EB"
                            CornerRadius="6"
                            Width="28" Height="28">
                        <TextBlock Text="V"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="VolleyStats"
                               FontWeight="SemiBold"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- New tab button -->
                <Button DockPanel.Dock="Right"
                        Content="+"
                        Command="{Binding AddTabCommand}"
                        Classes="ghost"
                        ToolTip.Tip="New tab"
                        FontSize="18"
                        FontWeight="Light"
                        Width="32" Height="32"
                        Padding="0"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>

                <!-- Tabs -->
                <ListBox ItemsSource="{Binding Tabs}"
                         SelectedItem="{Binding SelectedTab}"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding"         Value="0"/>
                            <Setter Property="Margin"          Value="1,8,0,0"/>
                            <Setter Property="CornerRadius"    Value="8,8,0,0"/>
                            <Setter Property="Background"      Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource SystemControlPageBackgroundAltHighBrush}"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                        </Style>
                        <!-- Blue underline on selected tab -->
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush"     Value="#2563EB"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:TabItemViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="13,5">
                                <TextBlock Text="{Binding Header}"
                                           VerticalAlignment="Center"
                                           FontSize="13"/>
                                <Button Content="✕"
                                        Command="{Binding CloseCommand}"
                                        Classes="ghost"
                                        FontSize="9"
                                        Width="16" Height="16"
                                        Padding="0"
                                        CornerRadius="4"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        ToolTip.Tip="Close tab"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- Tab content — ViewLocator resolves the correct view for each ViewModel -->
        <ContentControl Content="{Binding SelectedTab.Content}"/>

    </DockPanel>
</Window>
