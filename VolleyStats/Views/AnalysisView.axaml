<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:VolleyStats.ViewModels"
             mc:Ignorable="d"
             x:Class="VolleyStats.Views.AnalysisView"
             d:DesignWidth="1100"
             d:DesignHeight="700"
             x:DataType="viewmodels:AnalysisViewModel">

    <UserControl.Styles>
        <Style Selector="Button.analysis-card">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.analysis-card:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.analysis-card:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.analysis-card:pointerover Border.card">
            <Setter Property="RenderTransform" Value="translateY(-3px)" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="28,16,28,14"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Content="← Back"
                        Command="{Binding BackCommand}"
                        Padding="12,7"
                        VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Left"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Analysis"
                               FontSize="18"
                               FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <TextBlock Text="{Binding AnalysisTeam}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Text="·"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Text="{Binding MatchCount, StringFormat='{}{0} match(es)'}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="48,48,48,48"
                        MaxWidth="860"
                        HorizontalAlignment="Center"
                        Spacing="0">

                <!-- Section label -->
                <TextBlock Text="Choose analysis type"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="0,0,0,20"
                           LetterSpacing="1" />

                <!-- Cards row -->
                <WrapPanel Orientation="Horizontal">

                    <!-- Video Analysis card -->
                    <Button Classes="analysis-card"
                            Command="{Binding OpenVideoAnalysisCommand}"
                            Margin="0,0,20,20"
                            Width="340">
                        <Border Classes="card"
                                CornerRadius="14"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                Padding="28,26">
                            <StackPanel Spacing="0">

                                <!-- Icon circle -->
                                <Border Width="52" Height="52"
                                        CornerRadius="26"
                                        Background="#1D4ED8"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,18">
                                    <TextBlock Text="▶"
                                               FontSize="20"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="3,0,0,0" />
                                </Border>

                                <TextBlock Text="Video Analysis"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="Watch synchronized match footage with scout codes. Filter by player, skill, and evaluation."
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           Margin="0,0,0,22" />

                                <Border Background="#1D4ED8"
                                        CornerRadius="8"
                                        Padding="16,9"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="Open"
                                               Foreground="White"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>

                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Data Analysis card -->
                    <Button Classes="analysis-card"
                            Command="{Binding OpenDataAnalysisCommand}"
                            Margin="0,0,0,20"
                            Width="340">
                        <Border Classes="card"
                                CornerRadius="14"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                Padding="28,26">
                            <StackPanel Spacing="0">

                                <!-- Icon circle -->
                                <Border Width="52" Height="52"
                                        CornerRadius="26"
                                        Background="#7C3AED"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,18">
                                    <TextBlock Text="◎"
                                               FontSize="22"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <TextBlock Text="Data Analysis"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="Open a workspace to build your analysis. Add match reports, direction maps, and more as dockable panels."
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           Margin="0,0,0,22" />

                                <Border Background="#7C3AED"
                                        CornerRadius="8"
                                        Padding="16,9"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="Open"
                                               Foreground="White"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>

                            </StackPanel>
                        </Border>
                    </Button>

                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
