<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VolleyStats.HomeView">
    <Grid>
		
  <!-- Tlaèítko Teams vpravo nahoøe -->
        <Button x:Name="TeamsButton"
                Content="Teams"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                Click="TeamsButton_OnClick" />

        <!-- Dv́ tlaèítka uprostøed -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="20">

            <Button x:Name="ScoutMatchButton"
                    Content="Scout Match"
                    Width="130"
                    Height="40"
                    Click="ScoutMatchButton_OnClick"/>

            <Button x:Name="AnalysisButton"
                    Content="Analysis"
                    Width="130"
                    Height="40"
                    Click="AnalysisButton_OnClick"/>

        </StackPanel>
    </Grid>
</UserControl>
