<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VolleyStats.Views.EditCodeWindow"
        Title="Edit Code"
        Width="360"
        Height="140"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="Raw code:" />
        <TextBox x:Name="RawCodeTextBox" FontFamily="Consolas,Courier New,monospace" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="CancelButton_OnClick" />
            <Button Content="Save" Click="SaveButton_OnClick" />
        </StackPanel>
    </StackPanel>

</Window>
