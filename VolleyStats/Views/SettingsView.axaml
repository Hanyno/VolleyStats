<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:VolleyStats.ViewModels"
             mc:Ignorable="d"
             x:Class="VolleyStats.Views.SettingsView"
             x:DataType="viewmodels:SettingsViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Padding="20,12,20,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Content="← Back"
                        Command="{Binding BackCommand}"
                        Padding="12,7"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center"/>
                <TextBlock Text="Settings"
                           FontSize="17"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="36,28,36,28"
                        Spacing="20"
                        MaxWidth="680"
                        HorizontalAlignment="Left">

                <!-- Keyboard Bindings card -->
                <Border CornerRadius="12"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="22,20">
                    <StackPanel Spacing="14">

                        <!-- Section header -->
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="+ Add Binding"
                                    Classes="primary"
                                    Click="AddBindingButton_OnClick"
                                    Padding="12,6"/>
                            <TextBlock Text="Keyboard Bindings"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <TextBlock Text="Assign a key to automatically insert text into the scout code box."
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                        <!-- Bindings list -->
                        <ItemsControl ItemsSource="{Binding KeyBindings}"
                                      IsVisible="{Binding HasBindings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:KeyBindingViewModel">
                                    <Border Padding="12,8"
                                            Margin="0,0,0,4"
                                            CornerRadius="8"
                                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                            BorderThickness="1">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="✕"
                                                    Classes="ghost"
                                                    Command="{Binding RemoveCommand}"
                                                    Padding="7,4"
                                                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12"
                                                        VerticalAlignment="Center">
                                                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                        CornerRadius="5"
                                                        Padding="8,3">
                                                    <TextBlock Text="{Binding KeyGesture}"
                                                               FontFamily="Consolas,Courier New,monospace"
                                                               FontWeight="Bold"
                                                               FontSize="12"/>
                                                </Border>
                                                <TextBlock Text="→"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                <TextBlock Text="{Binding InsertText}"
                                                           FontFamily="Consolas,Courier New,monospace"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <TextBlock Text="No bindings yet. Click '+ Add Binding' to create one."
                                   IsVisible="{Binding !HasBindings}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,8"/>

                    </StackPanel>
                </Border>

                <!-- Video Rendering card -->
                <Border CornerRadius="12"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="22,20">
                    <StackPanel Spacing="14">

                        <TextBlock Text="Video Rendering"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Configure FFmpeg encoder for rendering compilation videos from selected actions."
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                        <!-- Encoder mode -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="Encoder:"
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                            <ComboBox ItemsSource="{Binding EncoderModeOptions}"
                                      SelectedItem="{Binding VideoEncoderMode}"
                                      MinWidth="180"/>
                        </StackPanel>

                        <!-- FFmpeg path -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="FFmpeg:"
                                           VerticalAlignment="Center"
                                           FontSize="13"/>
                                <TextBlock Text="{Binding FfmpegStatus}"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Text="{Binding FfmpegPath}"
                                         Watermark="Leave empty to use PATH"
                                         MinWidth="320"
                                         FontSize="12"/>
                                <Button Content="Browse..."
                                        Click="BrowseFfmpegButton_OnClick"
                                        Padding="12,6"/>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
