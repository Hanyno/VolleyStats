<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:VolleyStats.ViewModels"
             mc:Ignorable="d"
             x:Class="VolleyStats.Views.HomePageView"
             d:DesignWidth="1200"
             d:DesignHeight="800"
             x:DataType="viewmodels:HomePageViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Padding="20,12,20,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>

                <!-- Settings button — left -->
                <Button DockPanel.Dock="Left"
                        Content="⚙"
                        Classes="ghost"
                        Command="{Binding OpenSettingsCommand}"
                        Padding="10,8"
                        Margin="0,0,10,0"
                        FontSize="20"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Settings"/>

                <!-- Manage Teams button — right -->
                <Button DockPanel.Dock="Right"
                        Content="Manage Teams"
                        Click="TeamsButton_OnClick"
                        Padding="12,7"
                        VerticalAlignment="Center"/>

                <!-- App title -->
                <TextBlock Text="VolleyStats"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content: centered card with filters + match list -->
        <Border Grid.Row="1"
                MaxWidth="920"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Margin="24,24,24,24"
                CornerRadius="12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <Grid RowDefinitions="Auto,*">

                <!-- Filters bar -->
                <Border Grid.Row="0"
                        Padding="18,14"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel>

                        <!-- Action buttons — right -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    VerticalAlignment="Center">
                            <Button Content="+ New Match"
                                    Padding="12,6"/>
                            <Button Content="Analysis"
                                    Classes="primary"
                                    Command="{Binding AnalyzeCommand}"
                                    Padding="12,6"/>
                        </StackPanel>

                        <!-- Filter controls — left -->
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Season"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           FontSize="12"/>
                                <ComboBox Width="190"
                                          ItemsSource="{Binding AvailableSeasons}"
                                          SelectedItem="{Binding SelectedSeason, Mode=TwoWay}"/>
                            </StackPanel>

                            <Border Width="1" Height="20"
                                    Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    Margin="2,0,12,0"
                                    VerticalAlignment="Center"/>

                            <Button Content="{Binding TeamFilterButtonText}"
                                    Click="SelectTeamButton_OnClick"
                                    Padding="12,6"
                                    Margin="0,0,6,0"/>

                            <Button Content="Clear"
                                    IsEnabled="{Binding HasTeamFilter}"
                                    Classes="ghost"
                                    Click="ClearTeamFilterButton_OnClick"
                                    Padding="10,6"
                                    Margin="0,0,6,0"/>

                            <Button Content="{Binding SortButtonText}"
                                    Command="{Binding ToggleSortCommand}"
                                    Padding="10,6"
                                    ToolTip.Tip="Toggle sort order"/>

                            <Button Content="↻"
                                    Classes="ghost"
                                    Command="{Binding LoadMatchesCommand}"
                                    Padding="10,6"
                                    FontSize="15"
                                    ToolTip.Tip="Refresh"/>
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <!-- Match list -->
                <ListBox Grid.Row="1"
                         x:Name="MatchesList"
                         ItemsSource="{Binding Matches}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Margin="14,10,14,14">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding"          Value="0"/>
                            <Setter Property="Margin"           Value="0,0,0,7"/>
                            <Setter Property="Background"       Value="Transparent"/>
                            <Setter Property="BorderThickness"  Value="0"/>
                            <Setter Property="CornerRadius"     Value="10"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:MatchListItemViewModel">
                            <Border Padding="18,13"
                                    CornerRadius="10"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
                                <Interaction.Behaviors>
                                    <EventTriggerBehavior EventName="DoubleTapped">
                                        <InvokeCommandAction
                                            Command="{Binding $parent[ListBox].DataContext.OpenMatchCommand}"
                                            CommandParameter="{Binding}"/>
                                    </EventTriggerBehavior>
                                </Interaction.Behaviors>
                                <Grid ColumnDefinitions="Auto,88,*" ColumnSpacing="18">

                                    <!-- Select toggle -->
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="2,0,0,0"
                                              ToolTip.Tip="Select for analysis"/>

                                    <!-- Date & Time -->
                                    <StackPanel Grid.Column="1"
                                                Spacing="3"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DateText}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"/>
                                        <TextBlock Text="{Binding TimeText}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>

                                    <!-- Match: teams, score, league -->
                                    <StackPanel Grid.Column="2" Spacing="5">

                                        <!-- Score row -->
                                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="14">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding HomeTeam}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>

                                            <Border Grid.Column="1"
                                                    Background="#2563EB"
                                                    CornerRadius="8"
                                                    Padding="12,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ScoreText}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AwayTeam}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </Grid>

                                        <!-- League & Phase -->
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="{Binding LeagueText}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            <TextBlock Text="·"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            <TextBlock Text="{Binding PhaseText}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
