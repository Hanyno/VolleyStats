<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:VolleyStats.ViewModels"
             xmlns:views="using:VolleyStats.Views"
             mc:Ignorable="d"
             x:Class="VolleyStats.Views.MatchDetailView"
             d:DesignWidth="1200"
             d:DesignHeight="800"
             x:DataType="viewmodels:MatchDetailViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="24,14,24,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Left: Back + Edit buttons -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button Content="← Back"
                            Command="{Binding BackCommand}"
                            Padding="12,7"
                            VerticalAlignment="Center" />
                    <Button x:Name="EditInfoButton"
                            Content="✎ Match Info"
                            Padding="10,7"
                            VerticalAlignment="Center"
                            Click="EditInfoButton_OnClick" />
                    <Button Content="💾 Save"
                            Command="{Binding SaveCommand}"
                            Padding="10,7"
                            VerticalAlignment="Center" />
                    <Button Content="🎬 Video"
                            Padding="10,7"
                            VerticalAlignment="Center"
                            Click="ChangeVideoButton_OnClick" />
                </StackPanel>

                <!-- Right: Score badge -->
                <Border DockPanel.Dock="Right"
                        Background="#1D4ED8"
                        CornerRadius="8"
                        Padding="18,6"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ScoreText}"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold" />
                </Border>

                <!-- Center: team names + match info line -->
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding HomeTeamName}"
                                   FontSize="17" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="vs" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding AwayTeamName}"
                                   FontSize="17" FontWeight="SemiBold"
                                   HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="{Binding MatchInfoText}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               IsVisible="{Binding MatchInfoText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnDefinitions="260,*" ColumnSpacing="0">

            <!-- Left column: set scores + court + action buttons + codes list -->
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,Auto,Auto,Auto,*"
                  Margin="16,12,8,16">

                <!-- Row 0: Set scores + current set + live score + Start/End Set buttons -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,6"
                        Margin="0,0,0,6">
                    <StackPanel Spacing="4">
                        <!-- Top row: set label + past scores + action button -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SetManager.CurrentSet, StringFormat='Set {0}'}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       VerticalAlignment="Center" />

                            <ItemsControl Grid.Column="1"
                                          ItemsSource="{Binding SetManager.SetScores}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:SetScoreItemViewModel">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                CornerRadius="4"
                                                Padding="6,3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SetNumber, StringFormat='S{0}'}"
                                                           FontSize="9"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                                <TextBlock Text="{Binding ScoreText}"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <Button Content="End Set"
                                        Command="{Binding SetManager.EndSetCommand}"
                                        FontSize="11"
                                        Padding="6,3"
                                        IsVisible="{Binding SetManager.IsActiveSet}" />
                            </StackPanel>
                        </Grid>

                        <!-- Live score row (only when set is active) -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                IsVisible="{Binding SetManager.IsActiveSet}"
                                HorizontalAlignment="Stretch">
                            <Grid ColumnDefinitions="*,Auto,*">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding SetManager.LiveHomeScore}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text=":"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SetManager.LiveAwayScore}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Row 1: Away action buttons (above court) -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto,*"
                      ColumnSpacing="4"
                      Margin="0,0,0,3">
                    <Button Grid.Column="0"
                            Command="{Binding SetManager.AwayTimeoutCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="4,5">
                        <TextBlock>
                            <Run Text="T.O. " />
                            <Run Text="{Binding SetManager.AwayTimeoutsLeft}" FontWeight="Bold" />
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="1"
                            Command="{Binding SetManager.RotateAwayCommand}"
                            Content="↻"
                            FontSize="14"
                            Padding="10,4"
                            ToolTip.Tip="Rotate away team" />
                    <Button Grid.Column="2"
                            Command="{Binding SetManager.AwaySubstitutionCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="4,5">
                        <TextBlock>
                            <Run Text="Sub " />
                            <Run Text="{Binding SetManager.AwaySubstitutionsLeft}" FontWeight="Bold" />
                        </TextBlock>
                    </Button>
                </Grid>

                <!-- Row 2: Serving indicator (away) + Court + Serving indicator (home) -->
                <Grid Grid.Row="2" RowDefinitions="Auto,*,Auto">

                    <!-- Away serving ball (left, above zone 1) -->
                    <Button Grid.Row="0"
                            Command="{Binding SetManager.ToggleServingCommand}"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="12,0,0,1"
                            Cursor="Hand"
                            IsVisible="{Binding SetManager.IsActiveSet}">
                        <Panel Width="16" Height="16">
                            <Ellipse Width="14" Height="14"
                                     Fill="#FBBF24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     IsVisible="{Binding SetManager.IsAwayServing}" />
                            <Ellipse Width="14" Height="14"
                                     Stroke="#FBBF24" StrokeThickness="2"
                                     Fill="Transparent"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     IsVisible="{Binding SetManager.IsHomeServing}" />
                        </Panel>
                    </Button>

                    <!-- Court -->
                    <Border Grid.Row="1"
                            Height="190"
                            Background="#166534"
                            CornerRadius="6"
                            ClipToBounds="True">
                        <Panel>

                            <!-- Start Set button (when no active set) -->
                            <Button Content="▶  Start Set"
                                    IsVisible="{Binding SetManager.IsNotActiveSet}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Padding="24,12"
                                    Click="StartSetButton_OnClick" />

                            <!-- Court positions (when active set) -->
                            <Grid RowDefinitions="*,2,*"
                                  IsVisible="{Binding SetManager.IsActiveSet}">

                                <!-- Away half -->
                                <Grid Grid.Row="0">
                                    <Grid RowDefinitions="*,*" Margin="8,6,8,4">
                                        <!-- Away back row: 1, 6, 5 -->
                                        <Grid Grid.Row="0" ColumnDefinitions="*,*,*" VerticalAlignment="Center">
                                            <Border Grid.Column="0" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos1}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="1" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos6}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="2" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos5}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <!-- Away front row: 2, 3, 4 -->
                                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" VerticalAlignment="Center">
                                            <Border Grid.Column="0" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos2}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="1" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos3}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="2" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos4}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>

                                <!-- Net -->
                                <Border Grid.Row="1" Background="White" Opacity="0.7" />

                                <!-- Home half -->
                                <Grid Grid.Row="2">
                                    <Grid RowDefinitions="*,*" Margin="8,4,8,6">
                                        <!-- Home front row: 4, 3, 2 -->
                                        <Grid Grid.Row="0" ColumnDefinitions="*,*,*" VerticalAlignment="Center">
                                            <Border Grid.Column="0" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos4}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="1" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos3}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="2" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos2}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <!-- Home back row: 5, 6, 1 -->
                                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" VerticalAlignment="Center">
                                            <Border Grid.Column="0" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos5}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="1" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos6}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="2" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos1}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>

                            </Grid>

                        </Panel>
                    </Border>

                    <!-- Home serving ball (right, below zone 1) -->
                    <Button Grid.Row="2"
                            Command="{Binding SetManager.ToggleServingCommand}"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0,1,12,0"
                            Cursor="Hand"
                            IsVisible="{Binding SetManager.IsActiveSet}">
                        <Panel Width="16" Height="16">
                            <Ellipse Width="14" Height="14"
                                     Fill="#FBBF24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     IsVisible="{Binding SetManager.IsHomeServing}" />
                            <Ellipse Width="14" Height="14"
                                     Stroke="#FBBF24" StrokeThickness="2"
                                     Fill="Transparent"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     IsVisible="{Binding SetManager.IsAwayServing}" />
                        </Panel>
                    </Button>

                </Grid>

                <!-- Row 3: Home action buttons (below court) -->
                <Grid Grid.Row="3"
                      ColumnDefinitions="*,Auto,*"
                      ColumnSpacing="4"
                      Margin="0,3,0,0">
                    <Button Grid.Column="0"
                            Command="{Binding SetManager.HomeTimeoutCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="4,5">
                        <TextBlock>
                            <Run Text="T.O. " />
                            <Run Text="{Binding SetManager.HomeTimeoutsLeft}" FontWeight="Bold" />
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="1"
                            Command="{Binding SetManager.RotateHomeCommand}"
                            Content="↻"
                            FontSize="14"
                            Padding="10,4"
                            ToolTip.Tip="Rotate home team" />
                    <Button Grid.Column="2"
                            Command="{Binding SetManager.HomeSubstitutionCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="4,5">
                        <TextBlock>
                            <Run Text="Sub " />
                            <Run Text="{Binding SetManager.HomeSubstitutionsLeft}" FontWeight="Bold" />
                        </TextBlock>
                    </Button>
                </Grid>

                <!-- Row 4: Codes list -->
                <Border Grid.Row="4"
                        Margin="0,8,0,0"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0"
                                Padding="12,8"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Scout Codes"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <Border Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        CornerRadius="10"
                                        Padding="7,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CodesCount}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <ListBox Grid.Row="1"
                                 x:Name="CodesList"
                                 ItemsSource="{Binding Codes}"
                                 SelectedItem="{Binding SelectedCode, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:CodeViewModel">
                                    <TextBlock Text="{Binding RawCode}"
                                               FontFamily="Consolas,Courier New,monospace"
                                               FontSize="12"
                                               Padding="4,2" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

            </Grid>

            <!-- Right column: input row at top, video below -->
            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*"
                  Margin="8,12,16,16">

                <!-- Input row: HomeBtn | TextBox | AwayBtn -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Content="{Binding HomeTeamName}"
                            Command="{Binding AddHomePointCommand}"
                            IsEnabled="{Binding SetManager.IsActiveSet}"
                            Background="#1D4ED8"
                            Foreground="White"
                            Padding="18,9"
                            VerticalAlignment="Stretch" />
                    <TextBox Grid.Column="1"
                             x:Name="ScoutCodeBox"
                             Text="{Binding NewCodeText}"
                             Watermark="Scout code..."
                             VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            Content="{Binding AwayTeamName}"
                            Command="{Binding AddAwayPointCommand}"
                            IsEnabled="{Binding SetManager.IsActiveSet}"
                            Background="#166534"
                            Foreground="White"
                            Padding="18,9"
                            VerticalAlignment="Stretch" />
                </Grid>

                <!-- Video player -->
                <Border Grid.Row="1"
                        Margin="0,8,0,0"
                        CornerRadius="6"
                        ClipToBounds="True">
                    <views:VideoPlayerControl
                        x:Name="VideoPlayer" />
                </Border>

            </Grid>

        </Grid>

    </Grid>
</UserControl>
