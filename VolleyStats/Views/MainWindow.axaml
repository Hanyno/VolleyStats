<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="using:VolleyStats.ViewModels"
        mc:Ignorable="d"
        x:Class="VolleyStats.Views.MainWindow"
        d:DesignWidth="1000"
        d:DesignHeight="700"
        Title="VolleyStats"
        xmlns:vm="clr-namespace:VolleyStats.ViewModels"
        x:DataType="vm:MainWindowViewModel">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="12" Spacing="8">
            <TextBlock Text="Zápasy" FontSize="20" FontWeight="Bold" />

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Sezóna:" VerticalAlignment="Center" />
                <ComboBox Width="200"
                          ItemsSource="{Binding AvailableSeasons}"
                          SelectedItem="{Binding SelectedSeason, Mode=TwoWay}" />
                <Button Content="Načíst" Command="{Binding LoadMatchesCommand}" />
                <Button Content="{Binding TeamFilterButtonText}" Click="SelectTeamButton_OnClick" />
                <Button Content="Zrušit filtr" IsEnabled="{Binding HasTeamFilter}" Click="ClearTeamFilterButton_OnClick" />
                <Button Content="Teams" Click="TeamsButton_OnClick" />
            </StackPanel>
        </StackPanel>

        <ListBox Margin="12"
                 ItemsSource="{Binding Matches}">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:MatchListItemViewModel">
                    <Border Padding="10" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto" ColumnSpacing="10">
                            <StackPanel Grid.RowSpan="2" Orientation="Vertical" Spacing="2">
                                <TextBlock Text="{Binding DateText}" FontWeight="Bold" />
                                <TextBlock Text="{Binding TimeText}" Foreground="Gray" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding HomeTeam}" FontWeight="Bold" />
                                <TextBlock Text="{Binding HomeSetsText}" />
                                <TextBlock Text="-" />
                                <TextBlock Text="{Binding AwaySetsText}" />
                                <TextBlock Text="{Binding AwayTeam}" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding LeagueText}" Foreground="Gray" />
                                <TextBlock Text="·" Foreground="Gray" />
                                <TextBlock Text="{Binding PhaseText}" Foreground="Gray" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
