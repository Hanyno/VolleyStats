<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VolleyStats.ViewModels"
             mc:Ignorable="d"
             x:Class="VolleyStats.Views.MatchReportView"
             d:DesignWidth="1400"
             d:DesignHeight="900"
             x:DataType="vm:MatchReportViewModel">

    <UserControl.Styles>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,3" />
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserResizeColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Header (hidden when embedded in dock) -->
        <Border Grid.Row="0"
                Background="#2563EB"
                Padding="20,14"
                IsVisible="{Binding !IsEmbedded}">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Content="← Back"
                        Command="{Binding BackCommand}"
                        Padding="12,7"
                        Background="#1D4ED8"
                        Foreground="White"
                        CornerRadius="8"
                        VerticalAlignment="Center" />

                <Button DockPanel.Dock="Right"
                        Content="Export PDF"
                        Command="{Binding ExportPdfCommand}"
                        Padding="14,7"
                        Background="White"
                        Foreground="#2563EB"
                        FontWeight="SemiBold"
                        CornerRadius="8"
                        VerticalAlignment="Center" />

                <StackPanel DockPanel.Dock="Right"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12"
                               Foreground="#CBD5E1"
                               HorizontalAlignment="Right" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Match Report"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding League}"
                               FontSize="12"
                               Foreground="#CBD5E1"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Embedded toolbar (shown when in dock) -->
        <Border Grid.Row="0"
                Padding="12,8"
                IsVisible="{Binding IsEmbedded}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Export PDF"
                        Command="{Binding ExportPdfCommand}"
                        Padding="10,5"
                        Background="#2563EB"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="SemiBold"
                        CornerRadius="6"
                        VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <TextBlock Text="{Binding League}"
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsLoading}"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                ZIndex="10">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="200" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,24"
                        Spacing="0"
                        MinWidth="1200">

                <!-- Score header card (single match only) -->
                <Border CornerRadius="12"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        Padding="24,16"
                        Margin="0,0,0,16"
                        IsVisible="{Binding !IsTeamOnly}">
                    <Grid ColumnDefinitions="*,Auto,*">

                        <!-- Home team -->
                        <StackPanel Grid.Column="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,24,0">
                            <TextBlock Text="{Binding HomeTeamName}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                        </StackPanel>

                        <!-- Score -->
                        <Border Grid.Column="1"
                                Background="#2563EB"
                                CornerRadius="10"
                                Padding="20,8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding HomeSetsWon}"
                                           FontSize="28" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text=":"
                                           FontSize="28" FontWeight="Bold" Foreground="#CBD5E1" />
                                <TextBlock Text="{Binding AwaySetsWon}"
                                           FontSize="28" FontWeight="Bold" Foreground="White" />
                            </StackPanel>
                        </Border>

                        <!-- Away team -->
                        <StackPanel Grid.Column="2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="24,0,0,0">
                            <TextBlock Text="{Binding AwayTeamName}"
                                       FontSize="22"
                                       FontWeight="Bold" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Team aggregate header (team-only mode) -->
                <Border CornerRadius="12"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        Padding="24,16"
                        Margin="0,0,0,16"
                        IsVisible="{Binding IsTeamOnly}">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{Binding HomeTeamName}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding MatchDate}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Match info + Set scores row (single match only) -->
                <Grid ColumnDefinitions="*,*" Margin="0,0,0,16"
                      IsVisible="{Binding !IsTeamOnly}">
                    <!-- Match Info -->
                    <Border Grid.Column="0"
                            CornerRadius="10"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1"
                            Padding="20,14"
                            Margin="0,0,8,0">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" >
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Date" FontWeight="SemiBold" FontSize="12" Margin="0,0,16,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MatchDate}" FontSize="12" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Venue" FontWeight="SemiBold" FontSize="12" Margin="0,0,16,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Venue}" FontSize="12" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Referees" FontWeight="SemiBold" FontSize="12" Margin="0,0,16,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Referees}" FontSize="12" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="League" FontWeight="SemiBold" FontSize="12" Margin="0,0,16,0" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding League}" FontSize="12" />
                        </Grid>
                    </Border>

                    <!-- Set Scores -->
                    <Border Grid.Column="1"
                            CornerRadius="10"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1"
                            Padding="0"
                            Margin="8,0,0,0"
                            ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding SetScores}"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Set" Binding="{Binding SetNumber}" Width="50" />
                                <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="80" />
                                <DataGridTextColumn Header="Partial 1" Binding="{Binding Partial1}" Width="80" />
                                <DataGridTextColumn Header="Partial 2" Binding="{Binding Partial2}" Width="80" />
                                <DataGridTextColumn Header="Partial 3" Binding="{Binding Partial3}" Width="80" />
                                <DataGridTextColumn Header="Score" Binding="{Binding FinalScore}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- HOME TEAM STATS -->
                <Border CornerRadius="10"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        Margin="0,0,0,16"
                        ClipToBounds="True">
                    <StackPanel>
                        <!-- Team header -->
                        <Border Background="#2563EB" Padding="16,10">
                            <DockPanel>
                                <TextBlock Text="{Binding HomeTeamName}"
                                           FontSize="15" FontWeight="Bold" Foreground="White" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding HomeCoach}"
                                           FontSize="11" Foreground="#CBD5E1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                            </DockPanel>
                        </Border>

                        <DataGrid ItemsSource="{Binding HomePlayerStats}"
                                  AutoGenerateColumns="False"
                                  Margin="0,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding JerseyNumber}" Width="40" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                                <DataGridTextColumn Header="Sets" Binding="{Binding SetsPlayed}" Width="60" />
                                <DataGridTextColumn Header="S.Tot" Binding="{Binding ServeTot}" Width="55" />
                                <DataGridTextColumn Header="S.Err" Binding="{Binding ServeErr}" Width="55" />
                                <DataGridTextColumn Header="S.Pts" Binding="{Binding ServePts}" Width="55" />
                                <DataGridTextColumn Header="R.Tot" Binding="{Binding RecTot}" Width="55" />
                                <DataGridTextColumn Header="R.Err" Binding="{Binding RecErr}" Width="55" />
                                <DataGridTextColumn Header="R.Pos%" Binding="{Binding RecPosPercent}" Width="60" />
                                <DataGridTextColumn Header="R.(Exc%)" Binding="{Binding RecExcPercent}" Width="70" />
                                <DataGridTextColumn Header="A.Tot" Binding="{Binding AtkTot}" Width="55" />
                                <DataGridTextColumn Header="A.Err" Binding="{Binding AtkErr}" Width="55" />
                                <DataGridTextColumn Header="A.Blo" Binding="{Binding AtkBlo}" Width="55" />
                                <DataGridTextColumn Header="A.Pts" Binding="{Binding AtkPts}" Width="55" />
                                <DataGridTextColumn Header="A.Pts%" Binding="{Binding AtkPtsPercent}" Width="65" />
                                <DataGridTextColumn Header="BK" Binding="{Binding BlkPts}" Width="45" />
                                <DataGridTextColumn Header="Tot" Binding="{Binding TotalPoints}" Width="50" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Team totals -->
                        <Border Background="#1E3A5F" Padding="0,0" IsVisible="{Binding HomeTotals, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Grid ColumnDefinitions="40,150,60,55,55,55,55,55,60,70,55,55,55,55,65,45,50">
                                <Border Grid.Column="0" Grid.ColumnSpan="3" Padding="6,6">
                                    <TextBlock Text="Team Total" FontWeight="Bold" Foreground="White" FontSize="12" />
                                </Border>
                                <TextBlock Grid.Column="3" Text="{Binding HomeTotals.ServeTot}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="4" Text="{Binding HomeTotals.ServeErr}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="5" Text="{Binding HomeTotals.ServePts}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="6" Text="{Binding HomeTotals.RecTot}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="7" Text="{Binding HomeTotals.RecErr}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="8" Text="{Binding HomeTotals.RecPosPercent}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="9" Text="{Binding HomeTotals.RecExcPercent}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="10" Text="{Binding HomeTotals.AtkTot}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="11" Text="{Binding HomeTotals.AtkErr}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="12" Text="{Binding HomeTotals.AtkBlo}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="13" Text="{Binding HomeTotals.AtkPts}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="14" Text="{Binding HomeTotals.AtkPtsPercent}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="15" Text="{Binding HomeTotals.BlkPts}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="16" Text="{Binding HomeTotals.TotalPoints}" Foreground="White" FontWeight="Bold" FontSize="12" Padding="6,6" />
                            </Grid>
                        </Border>

                        <!-- Per-set stats -->
                        <DataGrid ItemsSource="{Binding HomeSetStats}"
                                  AutoGenerateColumns="False"
                                  Margin="0,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="" Binding="{Binding SetLabel}" Width="90" />
                                <DataGridTextColumn Header="S.Tot" Binding="{Binding ServeTot}" Width="55" />
                                <DataGridTextColumn Header="S.Err" Binding="{Binding ServeErr}" Width="55" />
                                <DataGridTextColumn Header="S.Pts" Binding="{Binding ServePts}" Width="55" />
                                <DataGridTextColumn Header="R.Tot" Binding="{Binding RecTot}" Width="55" />
                                <DataGridTextColumn Header="R.Err" Binding="{Binding RecErr}" Width="55" />
                                <DataGridTextColumn Header="R.Pos%" Binding="{Binding RecPosPercent}" Width="60" />
                                <DataGridTextColumn Header="R.(Exc%)" Binding="{Binding RecExcPercent}" Width="70" />
                                <DataGridTextColumn Header="A.Tot" Binding="{Binding AtkTot}" Width="55" />
                                <DataGridTextColumn Header="A.Err" Binding="{Binding AtkErr}" Width="55" />
                                <DataGridTextColumn Header="A.Blo" Binding="{Binding AtkBlo}" Width="55" />
                                <DataGridTextColumn Header="A.Pts" Binding="{Binding AtkPts}" Width="55" />
                                <DataGridTextColumn Header="A.Pts%" Binding="{Binding AtkPtsPercent}" Width="65" />
                                <DataGridTextColumn Header="BK" Binding="{Binding BlkPts}" Width="45" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- AWAY TEAM STATS (single match only) -->
                <Border CornerRadius="10"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        Margin="0,0,0,16"
                        ClipToBounds="True"
                        IsVisible="{Binding !IsTeamOnly}">
                    <StackPanel>
                        <!-- Team header -->
                        <Border Background="#16A34A" Padding="16,10">
                            <DockPanel>
                                <TextBlock Text="{Binding AwayTeamName}"
                                           FontSize="15" FontWeight="Bold" Foreground="White" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding AwayCoach}"
                                           FontSize="11" Foreground="#DCFCE7"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                            </DockPanel>
                        </Border>

                        <DataGrid ItemsSource="{Binding AwayPlayerStats}"
                                  AutoGenerateColumns="False"
                                  Margin="0,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding JerseyNumber}" Width="40" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                                <DataGridTextColumn Header="Sets" Binding="{Binding SetsPlayed}" Width="60" />
                                <DataGridTextColumn Header="S.Tot" Binding="{Binding ServeTot}" Width="55" />
                                <DataGridTextColumn Header="S.Err" Binding="{Binding ServeErr}" Width="55" />
                                <DataGridTextColumn Header="S.Pts" Binding="{Binding ServePts}" Width="55" />
                                <DataGridTextColumn Header="R.Tot" Binding="{Binding RecTot}" Width="55" />
                                <DataGridTextColumn Header="R.Err" Binding="{Binding RecErr}" Width="55" />
                                <DataGridTextColumn Header="R.Pos%" Binding="{Binding RecPosPercent}" Width="60" />
                                <DataGridTextColumn Header="R.(Exc%)" Binding="{Binding RecExcPercent}" Width="70" />
                                <DataGridTextColumn Header="A.Tot" Binding="{Binding AtkTot}" Width="55" />
                                <DataGridTextColumn Header="A.Err" Binding="{Binding AtkErr}" Width="55" />
                                <DataGridTextColumn Header="A.Blo" Binding="{Binding AtkBlo}" Width="55" />
                                <DataGridTextColumn Header="A.Pts" Binding="{Binding AtkPts}" Width="55" />
                                <DataGridTextColumn Header="A.Pts%" Binding="{Binding AtkPtsPercent}" Width="65" />
                                <DataGridTextColumn Header="BK" Binding="{Binding BlkPts}" Width="45" />
                                <DataGridTextColumn Header="Tot" Binding="{Binding TotalPoints}" Width="50" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Team totals -->
                        <Border Background="#0D4F27" Padding="0,0" IsVisible="{Binding AwayTotals, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Grid ColumnDefinitions="40,150,60,55,55,55,55,55,60,70,55,55,55,55,65,45,50">
                                <Border Grid.Column="0" Grid.ColumnSpan="3" Padding="6,6">
                                    <TextBlock Text="Team Total" FontWeight="Bold" Foreground="White" FontSize="12" />
                                </Border>
                                <TextBlock Grid.Column="3" Text="{Binding AwayTotals.ServeTot}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="4" Text="{Binding AwayTotals.ServeErr}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="5" Text="{Binding AwayTotals.ServePts}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="6" Text="{Binding AwayTotals.RecTot}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="7" Text="{Binding AwayTotals.RecErr}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="8" Text="{Binding AwayTotals.RecPosPercent}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="9" Text="{Binding AwayTotals.RecExcPercent}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="10" Text="{Binding AwayTotals.AtkTot}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="11" Text="{Binding AwayTotals.AtkErr}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="12" Text="{Binding AwayTotals.AtkBlo}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="13" Text="{Binding AwayTotals.AtkPts}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="14" Text="{Binding AwayTotals.AtkPtsPercent}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="15" Text="{Binding AwayTotals.BlkPts}" Foreground="White" FontWeight="SemiBold" FontSize="12" Padding="6,6" />
                                <TextBlock Grid.Column="16" Text="{Binding AwayTotals.TotalPoints}" Foreground="White" FontWeight="Bold" FontSize="12" Padding="6,6" />
                            </Grid>
                        </Border>

                        <!-- Per-set stats -->
                        <DataGrid ItemsSource="{Binding AwaySetStats}"
                                  AutoGenerateColumns="False"
                                  Margin="0,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="" Binding="{Binding SetLabel}" Width="90" />
                                <DataGridTextColumn Header="S.Tot" Binding="{Binding ServeTot}" Width="55" />
                                <DataGridTextColumn Header="S.Err" Binding="{Binding ServeErr}" Width="55" />
                                <DataGridTextColumn Header="S.Pts" Binding="{Binding ServePts}" Width="55" />
                                <DataGridTextColumn Header="R.Tot" Binding="{Binding RecTot}" Width="55" />
                                <DataGridTextColumn Header="R.Err" Binding="{Binding RecErr}" Width="55" />
                                <DataGridTextColumn Header="R.Pos%" Binding="{Binding RecPosPercent}" Width="60" />
                                <DataGridTextColumn Header="R.(Exc%)" Binding="{Binding RecExcPercent}" Width="70" />
                                <DataGridTextColumn Header="A.Tot" Binding="{Binding AtkTot}" Width="55" />
                                <DataGridTextColumn Header="A.Err" Binding="{Binding AtkErr}" Width="55" />
                                <DataGridTextColumn Header="A.Blo" Binding="{Binding AtkBlo}" Width="55" />
                                <DataGridTextColumn Header="A.Pts" Binding="{Binding AtkPts}" Width="55" />
                                <DataGridTextColumn Header="A.Pts%" Binding="{Binding AtkPtsPercent}" Width="65" />
                                <DataGridTextColumn Header="BK" Binding="{Binding BlkPts}" Width="45" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
