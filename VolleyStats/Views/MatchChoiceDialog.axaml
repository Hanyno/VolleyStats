<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VolleyStats.Views.MatchChoiceDialog"
        Width="300"
        Height="160"
        CanResize="False"
        Title="Scout match">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="What do you want to do?"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">

            <Button Content="Choose match"
                    Width="110"
                    Click="ChooseMatch_OnClick"/>

            <Button Content="Create match"
                    Width="110"
                    Click="CreateMatch_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
