<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VolleyStats.Views"
             x:Class="VolleyStats.Views.TeamAnalysisView">

    <Grid RowDefinitions="Auto,*" Margin="10">
        <views:TeamAnalysisFilterView x:Name="FilterView"
                                      Grid.Row="0" />

        <views:TeamAnalysisResultsView x:Name="ResultsView"
                                       Grid.Row="1"
                                       Margin="0,10,0,0" />
    </Grid>
</UserControl>