<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
        xmlns:ia="clr-namespace:Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
        xmlns:viewmodels="using:VolleyStats.ViewModels"
        xmlns:models="clr-namespace:VolleyStats.Models"
        mc:Ignorable="d"
        x:Class="VolleyStats.Views.TeamsWindow"
        Title="Teams"
        Width="620"
        MinWidth="480"
        Height="560"
        MinHeight="400"
        x:DataType="viewmodels:TeamsViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="22,16,22,14"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <Button Content="Import"
                            Command="{Binding ImportTeamsCommand}"
                            Padding="12,6"/>
                    <Button Content="New Team"
                            Classes="primary"
                            Command="{Binding NewTeamCommand}"
                            Padding="12,6"/>
                </StackPanel>
                <TextBlock Text="Teams"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Team list -->
        <ListBox Grid.Row="1"
                 x:Name="TeamsList"
                 ItemsSource="{Binding Teams}"
                 SelectedItem="{Binding SelectedTeam, Mode=TwoWay}"
                 SelectionMode="Single"
                 Background="Transparent"
                 BorderThickness="0"
                 Margin="14,10,14,4"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding"         Value="14,11"/>
                    <Setter Property="Margin"          Value="0,0,0,6"/>
                    <Setter Property="CornerRadius"    Value="10"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush"     Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentLowBrush}"/>
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Team">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Interaction.Behaviors>
                            <EventTriggerBehavior EventName="DoubleTapped">
                                <InvokeCommandAction
                                    Command="{Binding $parent[ListBox].DataContext.EditTeamCommand}"
                                    CommandParameter="{Binding}"/>
                            </EventTriggerBehavior>
                        </Interaction.Behaviors>

                        <!-- Code badge -->
                        <Border Grid.Column="0"
                                Background="#2563EB"
                                CornerRadius="6"
                                Padding="10,4"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding TeamCode}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="11"/>
                        </Border>

                        <!-- Name + Coach -->
                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding CoachName}"
                                       FontSize="12"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>

                        <!-- Abbreviation -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Abbreviation}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer actions -->
        <Border Grid.Row="2"
                Padding="22,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Content="Delete"
                        Classes="danger"
                        Command="{Binding DeleteSelectedTeamCommand}"
                        Padding="14,7"/>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="6"
                            HorizontalAlignment="Right">
                    <Button Content="Export"
                            Command="{Binding ExportSelectedTeamCommand}"
                            Padding="12,7"/>
                    <Button Content="Edit"
                            Classes="primary"
                            Command="{Binding EditSelectedTeamCommand}"
                            Padding="14,7"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>
