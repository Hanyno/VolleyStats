<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:VolleyStats.ViewModels"
             xmlns:views="using:VolleyStats.Views"
             mc:Ignorable="d"
             x:Class="VolleyStats.Views.MatchDetailView"
             d:DesignWidth="1200"
             d:DesignHeight="800"
             x:DataType="viewmodels:MatchDetailViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="20,12,20,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>

                <!-- Left: navigation + utility actions -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Button Content="← Back"
                            Command="{Binding BackCommand}"
                            Padding="12,7"
                            VerticalAlignment="Center"/>

                    <Border Width="1" Height="20"
                            Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            Margin="6,0"
                            VerticalAlignment="Center"/>

                    <Button x:Name="EditInfoButton"
                            Content="Edit Info"
                            Classes="ghost"
                            Padding="10,7"
                            VerticalAlignment="Center"
                            Click="EditInfoButton_OnClick"/>
                    <Button Content="Save"
                            Classes="ghost"
                            Command="{Binding SaveCommand}"
                            Padding="10,7"
                            VerticalAlignment="Center"/>
                    <Button Content="Video"
                            Classes="ghost"
                            Padding="10,7"
                            VerticalAlignment="Center"
                            Click="ChangeVideoButton_OnClick"/>
                </StackPanel>

                <!-- Right: Score badge -->
                <Border DockPanel.Dock="Right"
                        Background="#2563EB"
                        CornerRadius="10"
                        Padding="18,6"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ScoreText}"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>
                </Border>

                <!-- Center: team names + match info -->
                <StackPanel VerticalAlignment="Center" Spacing="2" Margin="16,0">
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding HomeTeamName}"
                                   FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="vs" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding AwayTeamName}"
                                   FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="{Binding MatchInfoText}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               IsVisible="{Binding MatchInfoText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnDefinitions="256,*" ColumnSpacing="0">

            <!-- Left column: set scores + court + action buttons + codes list -->
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,Auto,Auto,Auto,*"
                  Margin="14,12,8,14">

                <!-- Row 0: Set scores + live score + End Set -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10,8"
                        Margin="0,0,0,6">
                    <StackPanel Spacing="5">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SetManager.CurrentSet, StringFormat='Set {0}'}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>

                            <ItemsControl Grid.Column="1"
                                          ItemsSource="{Binding SetManager.SetScores}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:SetScoreItemViewModel">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                CornerRadius="6"
                                                Padding="6,3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SetNumber, StringFormat='S{0}'}"
                                                           FontSize="9"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                <TextBlock Text="{Binding ScoreText}"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Grid.Column="2"
                                    Content="End Set"
                                    Command="{Binding SetManager.EndSetCommand}"
                                    Classes="ghost"
                                    FontSize="11"
                                    Padding="6,3"
                                    IsVisible="{Binding SetManager.IsActiveSet}"/>
                        </Grid>

                        <!-- Live score (only when set is active) -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="8"
                                Padding="8,5"
                                IsVisible="{Binding SetManager.IsActiveSet}">
                            <Grid ColumnDefinitions="*,Auto,*">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding SetManager.LiveHomeScore}"
                                           FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text=":"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SetManager.LiveAwayScore}"
                                           FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Row 1: Away action buttons (above court) -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto,*"
                      ColumnSpacing="4"
                      Margin="0,0,0,3">
                    <Button Grid.Column="0"
                            Command="{Binding SetManager.AwayTimeoutCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="4,5">
                        <TextBlock>
                            <Run Text="T.O. "/>
                            <Run Text="{Binding SetManager.AwayTimeoutsLeft}" FontWeight="Bold"/>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="1"
                            Command="{Binding SetManager.RotateAwayCommand}"
                            Classes="ghost"
                            Content="↻"
                            FontSize="14"
                            Padding="10,4"
                            ToolTip.Tip="Rotate away team"/>
                    <Button Grid.Column="2"
                            Command="{Binding SetManager.AwaySubstitutionCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="4,5">
                        <TextBlock>
                            <Run Text="Sub "/>
                            <Run Text="{Binding SetManager.AwaySubstitutionsLeft}" FontWeight="Bold"/>
                        </TextBlock>
                    </Button>
                </Grid>

                <!-- Row 2: Serving indicator + Court + Serving indicator -->
                <Grid Grid.Row="2" RowDefinitions="Auto,*,Auto">

                    <!-- Away serving ball -->
                    <Button Grid.Row="0"
                            Command="{Binding SetManager.ToggleServingCommand}"
                            HorizontalAlignment="Left"
                            Classes="ghost"
                            Padding="0"
                            Margin="12,0,0,1"
                            Cursor="Hand"
                            IsVisible="{Binding SetManager.IsActiveSet}">
                        <Panel Width="16" Height="16">
                            <Ellipse Width="13" Height="13"
                                     Fill="#FBBF24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     IsVisible="{Binding SetManager.IsAwayServing}"/>
                            <Ellipse Width="13" Height="13"
                                     Stroke="#FBBF24" StrokeThickness="2"
                                     Fill="Transparent"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     IsVisible="{Binding SetManager.IsHomeServing}"/>
                        </Panel>
                    </Button>

                    <!-- Court -->
                    <Border Grid.Row="1"
                            Height="192"
                            Background="#166534"
                            CornerRadius="10"
                            ClipToBounds="True">
                        <Panel>

                            <!-- Start Set button -->
                            <Button Content="▶  Start Set"
                                    IsVisible="{Binding SetManager.IsNotActiveSet}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Padding="22,11"
                                    Click="StartSetButton_OnClick"/>

                            <!-- Court positions -->
                            <Grid RowDefinitions="*,2,*"
                                  IsVisible="{Binding SetManager.IsActiveSet}">

                                <!-- Away half -->
                                <Grid Grid.Row="0">
                                    <Grid RowDefinitions="*,*" Margin="8,6,8,4">
                                        <Grid Grid.Row="0" ColumnDefinitions="*,*,*" VerticalAlignment="Center">
                                            <Border Grid.Column="0" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos1}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="1" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos6}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="2" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos5}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" VerticalAlignment="Center">
                                            <Border Grid.Column="0" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos2}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="1" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos3}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="2" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#0D4F27" BorderBrush="#4ADE80" BorderThickness="2">
                                                <TextBlock Text="{Binding AwayPos4}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>

                                <!-- Net -->
                                <Border Grid.Row="1" Background="White" Opacity="0.6"/>

                                <!-- Home half -->
                                <Grid Grid.Row="2">
                                    <Grid RowDefinitions="*,*" Margin="8,4,8,6">
                                        <Grid Grid.Row="0" ColumnDefinitions="*,*,*" VerticalAlignment="Center">
                                            <Border Grid.Column="0" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos4}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="1" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos3}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="2" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos2}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" VerticalAlignment="Center">
                                            <Border Grid.Column="0" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos5}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="1" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos6}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="2" HorizontalAlignment="Center"
                                                    Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E3A5F" BorderBrush="#60A5FA" BorderThickness="2">
                                                <TextBlock Text="{Binding HomePos1}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>

                            </Grid>
                        </Panel>
                    </Border>

                    <!-- Home serving ball -->
                    <Button Grid.Row="2"
                            Command="{Binding SetManager.ToggleServingCommand}"
                            HorizontalAlignment="Right"
                            Classes="ghost"
                            Padding="0"
                            Margin="0,1,12,0"
                            Cursor="Hand"
                            IsVisible="{Binding SetManager.IsActiveSet}">
                        <Panel Width="16" Height="16">
                            <Ellipse Width="13" Height="13"
                                     Fill="#FBBF24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     IsVisible="{Binding SetManager.IsHomeServing}"/>
                            <Ellipse Width="13" Height="13"
                                     Stroke="#FBBF24" StrokeThickness="2"
                                     Fill="Transparent"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     IsVisible="{Binding SetManager.IsAwayServing}"/>
                        </Panel>
                    </Button>

                </Grid>

                <!-- Row 3: Home action buttons -->
                <Grid Grid.Row="3"
                      ColumnDefinitions="*,Auto,*"
                      ColumnSpacing="4"
                      Margin="0,3,0,0">
                    <Button Grid.Column="0"
                            Command="{Binding SetManager.HomeTimeoutCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="4,5">
                        <TextBlock>
                            <Run Text="T.O. "/>
                            <Run Text="{Binding SetManager.HomeTimeoutsLeft}" FontWeight="Bold"/>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="1"
                            Command="{Binding SetManager.RotateHomeCommand}"
                            Classes="ghost"
                            Content="↻"
                            FontSize="14"
                            Padding="10,4"
                            ToolTip.Tip="Rotate home team"/>
                    <Button Grid.Column="2"
                            Command="{Binding SetManager.HomeSubstitutionCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="4,5">
                        <TextBlock>
                            <Run Text="Sub "/>
                            <Run Text="{Binding SetManager.HomeSubstitutionsLeft}" FontWeight="Bold"/>
                        </TextBlock>
                    </Button>
                </Grid>

                <!-- Row 4: Codes list -->
                <Border Grid.Row="4"
                        Margin="0,8,0,0"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0"
                                Padding="12,9"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Scout Codes"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                                <Border Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        CornerRadius="10"
                                        Padding="7,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CodesCount}"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ListBox Grid.Row="1"
                                 x:Name="CodesList"
                                 ItemsSource="{Binding Codes}"
                                 SelectedItem="{Binding SelectedCode, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:CodeViewModel">
                                    <TextBlock Text="{Binding RawCode}"
                                               FontFamily="Consolas,Courier New,monospace"
                                               FontSize="12"
                                               Padding="6,3"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

            </Grid>

            <!-- Right column: input row + video -->
            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*"
                  Margin="8,12,14,14">

                <!-- Input row: HomeBtn | TextBox | AwayBtn -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Content="{Binding HomeTeamName}"
                            Command="{Binding AddHomePointCommand}"
                            IsEnabled="{Binding SetManager.IsActiveSet}"
                            Classes="team-home"
                            Padding="16,9"
                            VerticalAlignment="Stretch"/>
                    <TextBox Grid.Column="1"
                             x:Name="ScoutCodeBox"
                             Text="{Binding NewCodeText}"
                             Watermark="Scout code..."
                             VerticalAlignment="Center"/>
                    <Button Grid.Column="2"
                            Content="{Binding AwayTeamName}"
                            Command="{Binding AddAwayPointCommand}"
                            IsEnabled="{Binding SetManager.IsActiveSet}"
                            Classes="team-away"
                            Padding="16,9"
                            VerticalAlignment="Stretch"/>
                </Grid>

                <!-- Video player -->
                <Border Grid.Row="1"
                        Margin="0,8,0,0"
                        CornerRadius="10"
                        ClipToBounds="True">
                    <views:VideoPlayerControl x:Name="VideoPlayer"/>
                </Border>

            </Grid>

        </Grid>

    </Grid>
</UserControl>
