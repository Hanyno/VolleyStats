<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:VolleyStats.ViewModels"
             mc:Ignorable="d"
             x:Class="VolleyStats.Views.HomePageView"
             d:DesignWidth="1200"
             d:DesignHeight="800"
             x:DataType="viewmodels:HomePageViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Padding="20,14,20,14"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>

                <!-- Settings button — left -->
                <Button DockPanel.Dock="Left"
                        Content="⚙"
                        Command="{Binding OpenSettingsCommand}"
                        Padding="14,10"
                        Margin="0,0,12,0"
                        FontSize="22"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Settings" />

                <!-- Manage Teams button — right -->
                <Button DockPanel.Dock="Right"
                        Content="Manage Teams"
                        Click="TeamsButton_OnClick"
                        Padding="14,8"
                        VerticalAlignment="Center" />

                <!-- App title -->
                <TextBlock Text=""
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Content: centered card with filters + match list -->
        <Border Grid.Row="1"
                MaxWidth="900"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Margin="24,28,24,28"
                CornerRadius="12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <Grid RowDefinitions="Auto,*">

                <!-- Filters bar inside the card -->
                <Border Grid.Row="0"
                        Padding="20,16"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel>

                        <!-- Action buttons — right -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Content="+ New Match"
                                    Padding="12,6" />
                            <Button Content="Analysis"
                                    IsEnabled="{Binding HasSelectedMatches}"
                                    Padding="12,6" />
                        </StackPanel>

                        <!-- Filter controls — left -->
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Season"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           FontSize="13" />
                                <ComboBox Width="200"
                                          ItemsSource="{Binding AvailableSeasons}"
                                          SelectedItem="{Binding SelectedSeason, Mode=TwoWay}" />
                            </StackPanel>

                            <Border Width="1" Height="22"
                                    Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    Margin="2,0,12,0"
                                    VerticalAlignment="Center" />

                            <Button Content="{Binding TeamFilterButtonText}"
                                    Click="SelectTeamButton_OnClick"
                                    Padding="12,6"
                                    Margin="0,0,6,0" />

                            <Button Content="Clear Filter"
                                    IsEnabled="{Binding HasTeamFilter}"
                                    Click="ClearTeamFilterButton_OnClick"
                                    Padding="12,6"
                                    Margin="0,0,6,0" />

                            <Button Content="↻ Refresh"
                                    Command="{Binding LoadMatchesCommand}"
                                    Padding="12,6" />
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <!-- Match list -->
                <ListBox Grid.Row="1"
                         x:Name="MatchesList"
                         ItemsSource="{Binding Matches}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Margin="16,12,16,16">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="CornerRadius" Value="10" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:MatchListItemViewModel">
                            <Border Padding="20,14"
                                    CornerRadius="10"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
                                <Interaction.Behaviors>
                                    <EventTriggerBehavior EventName="DoubleTapped">
                                        <InvokeCommandAction
                                            Command="{Binding $parent[ListBox].DataContext.OpenMatchCommand}"
                                            CommandParameter="{Binding}" />
                                    </EventTriggerBehavior>
                                </Interaction.Behaviors>
                                <Grid ColumnDefinitions="Auto,96,*" ColumnSpacing="20">

                                    <!-- Select toggle -->
                                    <ToggleButton Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Width="30" Height="30"
                                                  CornerRadius="15"
                                                  Padding="0"
                                                  VerticalAlignment="Center"
                                                  FontSize="14"
                                                  FontWeight="Bold"
                                                  Content="✓"
                                                  ToolTip.Tip="Select match" />

                                    <!-- Date & Time -->
                                    <StackPanel Grid.Column="1"
                                                Spacing="3"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DateText}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14" />
                                        <TextBlock Text="{Binding TimeText}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                    </StackPanel>

                                    <!-- Match: teams, score, league -->
                                    <StackPanel Grid.Column="2" Spacing="6">

                                        <!-- Score row -->
                                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="16">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding HomeTeam}"
                                                       FontWeight="SemiBold"
                                                       FontSize="15"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />

                                            <Border Grid.Column="1"
                                                    Background="#1D4ED8"
                                                    CornerRadius="6"
                                                    Padding="14,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ScoreText}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AwayTeam}"
                                                       FontWeight="SemiBold"
                                                       FontSize="15"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </Grid>

                                        <!-- League & Phase -->
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding LeagueText}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                            <TextBlock Text="·"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                            <TextBlock Text="{Binding PhaseText}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
