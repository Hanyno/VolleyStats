<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VolleyStats.ViewModels"
             mc:Ignorable="d"
             x:Class="VolleyStats.Views.DataAnalysisView"
             d:DesignWidth="1400"
             d:DesignHeight="900"
             x:DataType="vm:DataAnalysisViewModel">

    <UserControl.Styles>
        <!-- Sidebar add-panel button -->
        <Style Selector="Button.sidebar-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.sidebar-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>

        <!-- Panel close / maximize button -->
        <Style Selector="Button.panel-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.panel-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#20000000" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="20,12,20,10"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Content="← Back"
                        Command="{Binding BackCommand}"
                        Padding="12,7"
                        VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Left"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Data Analysis"
                               FontSize="18"
                               FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <TextBlock Text="{Binding AnalysisTeam}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Text="·"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock Text="{Binding MatchCount, StringFormat='{}{0} match(es)'}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Body: Sidebar + Panels -->
        <Grid Grid.Row="1" ColumnDefinitions="220,*">

            <!-- Left sidebar: available panel types -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12,16">
                <StackPanel Spacing="4">
                    <TextBlock Text="ADD PANEL"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               LetterSpacing="1"
                               Margin="12,0,0,10" />

                    <ItemsControl ItemsSource="{Binding AvailablePanels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PanelTypeInfo">
                                <Button Classes="sidebar-item"
                                        Command="{Binding $parent[ItemsControl].((vm:DataAnalysisViewModel)DataContext).AddPanelCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <!-- Icon -->
                                        <Border Width="36" Height="36"
                                                CornerRadius="8"
                                                Background="{Binding Color}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="16"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <!-- Text -->
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Main panel area -->
            <Grid Grid.Column="1">

                <!-- Empty state -->
                <StackPanel IsVisible="{Binding ShowEmptyState}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <Border Width="64" Height="64"
                            CornerRadius="32"
                            Background="{DynamicResource SystemControlHighlightListLowBrush}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="+"
                                   FontSize="28"
                                   FontWeight="Light"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="No panels added yet"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Click a panel type on the left to add it to your workspace"
                               FontSize="13"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Panels list -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding !ShowEmptyState}">
                    <ItemsControl ItemsSource="{Binding Panels}"
                                  Margin="12,12,12,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:DockPanelViewModel">
                                <Border CornerRadius="10"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        Margin="0,0,0,12"
                                        ClipToBounds="True">
                                    <Grid RowDefinitions="Auto,*">
                                        <!-- Panel title bar -->
                                        <Border Grid.Row="0"
                                                Background="{Binding Color}"
                                                Padding="12,8">
                                            <DockPanel>
                                                <!-- Close button -->
                                                <Button DockPanel.Dock="Right"
                                                        Classes="panel-btn"
                                                        Command="{Binding CloseCommand}"
                                                        ToolTip.Tip="Close panel">
                                                    <TextBlock Text="✕"
                                                               FontSize="13"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Button>

                                                <!-- Title -->
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Icon}"
                                                               FontSize="14"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>

                                        <!-- Panel content (auto-resolved via ViewLocator) -->
                                        <ContentControl Grid.Row="1"
                                                        Content="{Binding Content}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
