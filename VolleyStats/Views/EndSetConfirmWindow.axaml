<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:Class="VolleyStats.Views.EndSetConfirmWindow"
        Title="End Set?"
        Width="300"
        SizeToContent="Height"
        MinHeight="140"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20,18,20,16" Spacing="14">

        <TextBlock x:Name="TitleText"
                   FontSize="15"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />

        <TextBlock x:Name="ScoreText"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <TextBlock Text="End this set?"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="10"
                    Margin="0,4,0,0">
            <Button Content="Continue Playing"
                    Click="ContinueButton_OnClick"
                    Padding="12,7" />
            <Button Content="End Set"
                    Click="EndSetButton_OnClick"
                    Background="#1D4ED8"
                    Foreground="White"
                    Padding="12,7" />
        </StackPanel>

    </StackPanel>

</Window>
