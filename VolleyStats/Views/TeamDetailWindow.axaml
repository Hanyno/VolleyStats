<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:domain="clr-namespace:VolleyStats.Domain"
        xmlns:enums="clr-namespace:VolleyStats.Enums"
        mc:Ignorable="d"
        x:Class="VolleyStats.Views.TeamDetailWindow"
        x:CompileBindings="False"
        Width="960"
        MinWidth="800"
        Height="660"
        MinHeight="500"
        Title="Team Detail">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="28,20,28,16"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="Team Detail"
                       FontSize="22"
                       FontWeight="Bold" />
        </Border>

        <!-- Form fields -->
        <StackPanel Grid.Row="1"
                    Margin="28,20,28,0"
                    Spacing="16">

            <!-- Row 1: Code | Name | Abbreviation -->
            <Grid ColumnDefinitions="90,*,130"
                  ColumnSpacing="16">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="Code"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBox Text="{Binding TeamCode}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock Text="Team Name"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBox Text="{Binding Name}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="5">
                    <TextBlock Text="Abbreviation"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBox Text="{Binding Abbreviation}" />
                </StackPanel>
            </Grid>

            <!-- Row 2: Coach | Assistant Coach -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="16">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="Coach"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBox Text="{Binding CoachName}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock Text="Assistant Coach"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBox Text="{Binding AssistantCoachName}" />
                </StackPanel>
            </Grid>

        </StackPanel>

        <!-- Players section header -->
        <Border Grid.Row="2"
                Margin="0,20,0,0"
                Padding="28,12,28,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button Content="Remove Selected"
                            Command="{Binding RemovePlayerCommand}"
                            Padding="12,6" />
                    <Button Content="Add Player"
                            Command="{Binding AddPlayerCommand}"
                            Padding="12,6" />
                </StackPanel>
                <TextBlock Text="Players"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Players DataGrid -->
        <DataGrid Grid.Row="3"
                  x:Name="PlayersGrid"
                  Margin="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="All"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  ItemsSource="{Binding Players}"
                  SelectedItem="{Binding SelectedPlayer, Mode=TwoWay}">
            <DataGrid.Columns>

                <DataGridTextColumn Binding="{Binding JerseyNumber}"
                                    Header="#"
                                    Width="44" />

                <DataGridTextColumn Binding="{Binding PlayerRole}"
                                    Header="Role"
                                    Width="54" />

                <DataGridTextColumn Binding="{Binding ExternalPlayerId}"
                                    Header="Code"
                                    Width="70" />

                <DataGridTextColumn Binding="{Binding LastName}"
                                    Header="Last Name"
                                    Width="*" />

                <DataGridTextColumn Binding="{Binding FirstName}"
                                    Header="First Name"
                                    Width="*" />

                <DataGridTemplateColumn Header="Birth Date"
                                        Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding BirthDate, StringFormat='yyyy-MM-dd'}"
                                       VerticalAlignment="Center"
                                       Margin="12,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding BirthDate}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Binding="{Binding HeightCm}"
                                    Header="Height"
                                    Width="64" />

                <DataGridTemplateColumn Header="Position"
                                        Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Position}"
                                       VerticalAlignment="Center"
                                       Margin="12,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{x:Static enums:EnumSources.PlayerPosts}"
                                      SelectedItem="{Binding Position}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Binding="{Binding NickName}"
                                    Header="Nickname"
                                    Width="100" />

                <DataGridCheckBoxColumn Binding="{Binding IsForeign}"
                                        Header="Foreign"
                                        Width="64" />

                <DataGridCheckBoxColumn Binding="{Binding TransferredOut}"
                                        Header="Out"
                                        Width="48" />

            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="4"
                Padding="28,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Content="Delete Team"
                        Command="{Binding DeleteCommand}"
                        Background="#DC2626"
                        Foreground="White"
                        Padding="14,8" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Padding="14,8" />
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Padding="14,8" />
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>
